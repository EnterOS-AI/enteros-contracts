{
  "name": "@molecule-ai/contracts",
  "version": "0.1.0",
  "description": "Generated TypeScript bindings for the molecule-ai contract SSOT (molecule-contracts / RFC molecule-core#3285). MCP plugin-delivery scalars + workspace-comms message types.",
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://git.moleculesai.app/molecule-ai/molecule-contracts.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/gen/ts/contract_gen.d.ts",
      "default": "./dist/gen/ts/contract_gen.js"
    },
    "./workspace-comms": {
      "types": "./dist/gen/ts/workspace_comms_gen.d.ts",
      "default": "./dist/gen/ts/workspace_comms_gen.js"
    }
  },
  "files": [
    "dist",
    "gen/ts",
    "index.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "registry": "https://git.moleculesai.app/api/packages/molecule-ai/npm/"
  }
}
